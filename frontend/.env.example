# Copy to .env and adjust. Rebuild (`npm run build`) after changing VITE_* for production.

# Laravel API origin (no trailing /api) — same host you open in the browser for /sanctum if applicable
VITE_API_URL=http://localhost:8000

# Pusher Channels (must match the Laravel .env Pusher app: same key + same cluster)
# If cluster is wrong, the socket connects but you will not receive events.
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=ap2
