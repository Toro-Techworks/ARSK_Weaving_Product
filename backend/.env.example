# Use "pusher" for real-time super-admin notifications. "log" / "null" = nothing is sent to the browser.
# IMPORTANT: define BROADCAST_CONNECTION only ONCE (duplicates can leave you stuck on "log").
BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
CACHE_PREFIX=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,arsk.torotech.in,www.arsk.torotech.in
SPA_URL=https://arsk.torotech.in
# Comma-separated CORS origins (e.g. local dev + production frontend URL)
CORS_ORIGINS=http://localhost:5173,https://arsk.torotech.in
SESSION_DOMAIN=.arsk.torotech.in

